# Copy to examples/.env, replace every placeholder with a controlled test value,
# then source it in your shell. Do not commit examples/.env or real credentials.
TELLO_API_KEY='tello_live_...'
TELLO_URL='wss://your-staging-gateway.example/sdk'
LIVE_CALL_TO='+8210...controlled-test-recipient'
LIVE_CALL_TIMEOUT_SECONDS=120

# Keep false until every recipient above is a controlled test recipient.
ALLOW_LIVE_SIDE_EFFECTS=false

# Optional, clearly marked deterministic live-scenario content.
LIVE_CALL_PROMPT='Run a controlled SDK live scenario and keep the conversation brief.'
LIVE_CALL_REPLY='This is a controlled TPG SDK live scenario. Thank you.'
